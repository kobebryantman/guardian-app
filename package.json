{
  "name": "guardian-app",
  "version": "1.0.0",
  "description": "Guardian 访问守卫 - 机房网页访问管控",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "server": "node server.js",
    "build": "electron-builder --win --dir"
  },
  "keywords": [
    "electron",
    "guardian",
    "白名单",
    "机房管控"
  ],
  "author": "Guardian",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^11.9.1",
    "express": "^5.2.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "docx": "^9.6.1",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.guardian.app",
    "productName": "Guardian访问守卫",
    "copyright": "Copyright © 2026 Guardian",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "server.js",
      "remote-client.js",
      "public/**/*",
      "data/**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/.cache/**"
    ],
    "extraResources": [
      {
        "from": "data",
        "to": "data",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/renderer/icon.png"
    },
    "asar": true,
    "npmRebuild": false
  }
}
