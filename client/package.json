{
  "name": "guardian-client",
  "version": "1.0.0",
  "private": true,
  "description": "Guardian 学生端 - Electron 访问守卫",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --dir"
  },
  "dependencies": {
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^35.2.1",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.guardian.app",
    "productName": "Guardian访问守卫",
    "copyright": "Copyright © 2026 Guardian",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "data/**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/.cache/**"
    ],
    "extraResources": [
      {
        "from": "data",
        "to": "data",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": ["x64"]
        }
      ],
      "icon": "src/renderer/icon.png"
    },
    "asar": true,
    "npmRebuild": false
  }
}
